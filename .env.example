# ─── VENTURE OS — API KEYS ──────────────────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.
#
# Auditbound operator merge (merge these into your existing .env if upgrading):
#   RESEND_FROM_EMAIL=outreach@abtmail.co
#   RESEND_FROM_NAME=Ismael Sudally
#   ALLOWED_SENDER_DOMAINS=abtmail.co
#   DIGEST_TO_EMAIL=isudally@outlook.com
#   OUTREACH_SIGNATURE=Best,\nIsmael Sudally\nAuditbound\nOutbound accountability for agencies

# ─── Canonical Auditbound outbound (clone checklist) ─────────────────────────
ALLOWED_SENDER_DOMAINS=abtmail.co
RESEND_FROM_EMAIL=outreach@abtmail.co
RESEND_DOMAIN_VERIFIED=false
OUTREACH_SIGNATURE=Best,\nIsmael Sudally\nAuditbound\nOutbound accountability for agencies

# Outbound MIME + compliance (send_guard assembles html+text, footers, optional List-Unsubscribe)
EMAIL_SIGNATURE_HTML=<div style='font-family:Arial,sans-serif;font-size:14px;color:#222;line-height:1.5;'><table cellpadding='0' cellspacing='0' role='presentation' style='width:100%;'><tr><td style='padding-right:12px;vertical-align:top;width:56px;'><img src='https://auditbound.io/logo.png' alt='Auditbound' width='48' height='48' style='display:block;width:48px;height:48px;object-fit:contain;border:0;'></td><td style='vertical-align:top;'><strong>Ismael Sudally</strong><br>Founder, Auditbound<br>Outbound accountability for agencies<br><a href='https://auditbound.io'>auditbound.io</a> | <a href='mailto:outreach@abtmail.co'>outreach@abtmail.co</a><br><a href='https://cal.com/ismael-sudally/auditbound-campaign-audit-call'>Book a 20-min campaign audit call</a></td></tr></table></div>
EMAIL_SIGNATURE_TEXT=Ismael Sudally\nFounder, Auditbound\nOutbound accountability for agencies\nauditbound.io | isudally@outlook.com\n\nBook a 20-min campaign audit call:\nhttps://cal.com/ismael-sudally/auditbound-campaign-audit-call
CALENDLY_BOOKING_URL=https://calendly.com/YOUR_LINK
LIST_UNSUBSCRIBE_URL=
ENABLE_LIST_UNSUBSCRIBE=false
ENABLE_LIST_UNSUBSCRIBE_POST=false
ENABLE_SUPPRESSION_CHECKS=true
ALLOW_OPERATOR_OVERRIDE=false
VENTURE_PREFLIGHT_DOMAIN_DENYLIST=
VENTURE_SKIP_DNS_CHECKS=0
SEND_JITTER_SECONDS_MIN=30
SEND_JITTER_SECONDS_MAX=90

# OpenAI — idea scoring, outreach generation, KPI analysis, pivot decisions
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# Apollo.ai — automated competitor research
# Get key: https://platform.apollo.io/api-keys (update with your real key)
APOLLO_API_KEY=...

# Hunter.io — find verified email addresses for prospects (free: 25 searches/month)
# Get key: https://hunter.io/api
HUNTER_API_KEY=...

# Resend — send cold emails programmatically (free: 3,000 emails/month)
# Get key: https://resend.com/api-keys
# RESEND_FROM_EMAIL must be a verified domain in your Resend account
RESEND_API_KEY=re_...
# Sending domain (verify in Resend + DNS on abtmail.co). Brand: auditbound.io (verify only if used in Resend).
RESEND_FROM_EMAIL=outreach@abtmail.co
RESEND_FROM_NAME=Ismael Sudally

# ─── AUTO-SEND & FOLLOW-UP ───────────────────────────────────────────────────
# Set AUTO_SEND_EMAILS=true ONLY after testing — this will send real emails!
# DIGEST_TO_EMAIL receives a KPI summary after every pipeline run
AUTO_SEND_EMAILS=false
OUTREACH_TEST_TO=
INTERNAL_TEST_RECIPIENTS=
BATCH_LOCK_SECRET=
# Sender domain / verification: see "Canonical Auditbound outbound" block above.
ENABLE_FOLLOWUPS=false
ENABLE_SEND_EMAIL_RETRIES=false
FOLLOWUP_DAYS=4
DIGEST_TO_EMAIL=isudally@outlook.com
SEND_DAILY_CAP=40
SEND_HOURLY_CAP=6
SEND_START_HOUR=8
SEND_END_HOUR=18
ACTIVE_CLIENT_CAPACITY=6
ACTIVE_CLIENTS_CURRENT=0

# Reply-intent pre-send filter (logistic model in venture-engine/config/reply_intent.model.json)
REPLY_INTENT_ENABLED=false
REPLY_INTENT_MIN_PROB=0.12
# Below this trailing-7d send count, reply-intent filter is bypassed (low-volume protection)
REPLY_INTENT_VOLUME_THRESHOLD=12

INTEGRITY_MIN_REPLY_RATE=0.03
INTEGRITY_MIN_REPLY_RATE_24H=0.02
INTEGRITY_MAX_REPLY_DROP_DELTA=0.08
INTEGRITY_MAX_BLOCK_RATIO=0.60
INTEGRITY_MAX_FAILED_JOBS=25

# Airtable — cloud database for prospects and KPIs (free tier available)
# Get key: https://airtable.com/create/tokens
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_PROSPECTS_TABLE=Prospects
AIRTABLE_KPIS_TABLE=WeeklyKPIs

# Calendly — read booked calls (optional, for auto-KPI tracking)
# Get key: https://developer.calendly.com/api-docs
CALENDLY_API_KEY=...

# ─── NOTION ──────────────────────────────────────────────────────────────────
# Notion is your primary workspace hub — ideas, prospects, KPIs and decisions
# all sync here automatically.
#
# STEP 1 — Create an integration:
#   Go to https://www.notion.so/my-integrations → New integration
#   Name it "Venture OS" → copy the Internal Integration Secret below
#
# STEP 2 — Create 4 databases in Notion (or use existing ones):
#   Ideas DB      — columns: Name, Niche, Score, Status, Notes, Date
#   Prospects DB  — columns: Name, Company, Role, Industry, Pain Point, Email, LinkedIn, Status, Message
#   KPIs DB       — columns: Week Ending, Outreach Sent, Replies, Calls, Closed, Revenue, Churn, Notes
#   Decisions DB  — columns: Decision, Topic, Reason, Next Action, Date
#
# STEP 3 — Share each database with your "Venture OS" integration:
#   Open the database page → ··· menu → Connections → Add "Venture OS"
#
# STEP 4 — Copy each database ID from the URL:
#   Open database in browser: notion.so/{workspace}/{DATABASE_ID}?v=...
#   The 32-char string before "?v=" is the database ID
#
NOTION_API_KEY=secret_...
# Official Notion MCP (npx) reads NOTION_TOKEN — use the same value as NOTION_API_KEY unless you split them.
NOTION_TOKEN=
NOTION_IDEAS_DB=
NOTION_PROSPECTS_DB=
NOTION_KPIS_DB=
NOTION_DECISIONS_DB=

# ─── VENTURE SETTINGS ────────────────────────────────────────────────────────
YOUR_NAME=
YOUR_EMAIL=
YOUR_SERVICE=Lead-generation tool for B2B service firms (one market, structured targeting, safeguards, reply visibility)
YOUR_UNIQUE_VALUE=
YOUR_SOCIAL_PROOF=
# OUTREACH_SIGNATURE: see "Canonical Auditbound outbound" block above.
OUTREACH_FORMAT=LinkedIn DM
OUTREACH_MAX_WORDS=80
REVENUE_TARGET=10000
DASHBOARD_PORT=5000

# Motion engine routing controls (Credibility Launch)
MOTION_HOT_THRESHOLD=7
MOTION_POSSIBLE_THRESHOLD=5
MOTION_HOT_CAP=25
MOTION_POSSIBLE_SAMPLE_SIZE=10
MOTION_SHADOW_MODE=true

# Spend-trigger engine controls (must pass before HOT routing)
SPEND_FILTER_REQUIRED=true
SPEND_MIN_TRIGGER_COUNT=1

# V3: Conversion Intent Score (CIS) configuration
# CIS_ROUTING_MODE: "dual_shadow" (both v2 & v3), "v2_only" (legacy), "v3_only" (new)
CIS_ROUTING_MODE=dual_shadow
# CIS thresholds for routing bands (0-100)
CIS_HOT_THRESHOLD=80
CIS_POSSIBLE_THRESHOLD=50

# Resend webhooks (dashboard /webhooks/resend) — set signing secret from Resend dashboard (starts with whsec_)
# For local dev only, you may set VENTURE_ALLOW_INSECURE_WEBHOOKS=true (never in production).
RESEND_WEBHOOK_SIGNING_SECRET=
VENTURE_ALLOW_INSECURE_WEBHOOKS=false

# Phase B: delivery health (webhooks + send-time gates). Ratios use webhook events vs outbound sent in window.
VENTURE_DELIVERY_HEALTH_GATES=true
VENTURE_DELIVERY_HEALTH_MIN_SENDS=20
VENTURE_DELIVERY_METRICS_DAYS=7
VENTURE_BOUNCE_HARD_RATIO=0.12
VENTURE_BOUNCE_WARN_RATIO=0.06
VENTURE_COMPLAINT_HARD_RATIO=0.003
VENTURE_COMPLAINT_WARN_RATIO=0.001
VENTURE_APPROVAL_USER=

# Phase C: launch executor + TTY monitor (May 18 window)
LAUNCH_BOUNCE_EMERGENCY_RATIO=0.05
LAUNCH_MONITOR_BOUNCE_OK_PCT=5
LAUNCH_MONITOR_COMPLAINT_OK_PCT=0.3

# Phase D: domain warmup label (cold | warm | hot) for preflight_safety_check.py
DOMAIN_WARMUP_STAGE=cold
