  "change_impact_rules": {
    "message_change": {
      "risk": "can reduce fair comparison with previous message versions",
      "updates": [
        "comparison.json",
        "health.json",
        "dashboard.html",
        "value_summary.json"
      ]
    },
    "target_change": {
      "risk": "rate comparisons may no longer be apples-to-apples",
      "updates": [
        "run_report.json",
        "comparison.json",
        "trend_projection.json"
      ]
    },
    "timing_change": {
      "risk": "timing shift can hide true message effect",
      "updates": [
        "run_report.json",
        "comparison.json",
        "trend_summary.json"
      ]
    }
  },
